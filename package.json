{
  "name": "---name---",
  "version": "1.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "license": "MIT",
  "description": "A minimal starter for small TypeScript libraries and packages.",
  "repository": {
    "type": "git",
    "url": "---repo---"
  },
  "author": "Everett Morgan",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf coverage dist",
    "lint": "eslint . --max-warnings=0",
    "prepack": "yarn build",
    "release": "npm publish",
    "test": "yarn lint && yarn typecheck && yarn tests",
    "test-publish": "npm pack --dry-run --cache .npm",
    "tests": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  },
  "resolutions": {
    "flatted@npm:^3.2.9": "npm:3.4.2",
    "semver@npm:^6.0.0": "npm:6.3.1"
  },
  "packageManager": "yarn@4.14.1"
}
